<Window x:Class="PolyclinicApp.Views.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Пользователи"
        Height="740"
        Width="1180"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid Background="#F5F5F5" Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Управление пользователями"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <materialDesign:Card Grid.Row="1"
                             Padding="18"
                             Margin="0,0,0,18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="LoginTextBox"
                         Grid.Row="0"
                         Grid.Column="0"
                         Margin="0,0,10,12"
                         materialDesign:HintAssist.Hint="Логин"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <PasswordBox x:Name="PasswordBox"
                             Grid.Row="0"
                             Grid.Column="1"
                             Margin="0,0,10,12"
                             materialDesign:HintAssist.Hint="Пароль"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"/>

                <ComboBox x:Name="RoleComboBox"
                          Grid.Row="0"
                          Grid.Column="2"
                          Margin="0,0,10,12"
                          materialDesign:HintAssist.Hint="Роль"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="RoleComboBox_SelectionChanged"/>

                <ComboBox x:Name="DoctorComboBox"
                          Grid.Row="0"
                          Grid.Column="3"
                          Margin="0,0,10,12"
                          materialDesign:HintAssist.Hint="Врач"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"/>

                <Button Grid.Row="0"
                        Grid.Column="4"
                        Content="Очистить"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="ClearButton_Click"/>

                <TextBox x:Name="DoctorSearchTextBox"
                         Grid.Row="1"
                         Grid.Column="0"
                         Grid.ColumnSpan="3"
                         Margin="0,0,10,0"
                         materialDesign:HintAssist.Hint="Поиск врача для привязки"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="DoctorSearchTextBox_TextChanged"/>

                <TextBlock x:Name="HintTextBlock"
                           Grid.Row="1"
                           Grid.Column="3"
                           Grid.ColumnSpan="2"
                           VerticalAlignment="Center"
                           Foreground="Gray"
                           FontSize="14"
                           Text="Для роли «Врач» выберите связанного врача."/>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,12">

                <Button Content="Добавить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="AddButton_Click"/>

                <Button Content="Изменить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="EditButton_Click"/>

                <Button Content="Удалить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="DeleteButton_Click"/>

                <TextBox x:Name="SearchTextBox"
                         Width="360"
                         Margin="20,0,10,0"
                         materialDesign:HintAssist.Hint="Поиск по логину, роли или врачу"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="SearchTextBox_TextChanged"/>

                <Button Content="Обновить"
                        Width="130"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="RefreshButton_Click"/>
            </StackPanel>

            <ListView x:Name="UsersListView"
                      Grid.Row="1"
                      SelectionChanged="UsersListView_SelectionChanged">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID"
                                        Width="70"
                                        DisplayMemberBinding="{Binding UserId}"/>

                        <GridViewColumn Header="Логин"
                                        Width="180"
                                        DisplayMemberBinding="{Binding Login}"/>

                        <GridViewColumn Header="Роль"
                                        Width="160"
                                        DisplayMemberBinding="{Binding RoleName}"/>

                        <GridViewColumn Header="Врач"
                                        Width="320"
                                        DisplayMemberBinding="{Binding DoctorName}"/>

                        <GridViewColumn Header="ID врача"
                                        Width="100"
                                        DisplayMemberBinding="{Binding DoctorIdText}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</Window>