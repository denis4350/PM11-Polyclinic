<Window x:Class="PolyclinicApp.Views.ScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Расписание"
        Height="760"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid Background="#F5F5F5" Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Расписание врачей"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <materialDesign:Card Grid.Row="1"
                             Padding="18"
                             Margin="0,0,0,18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="1.7*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="DoctorSearchTextBox"
                         Grid.Row="0"
                         Grid.Column="0"
                         Margin="0,0,10,12"
                         materialDesign:HintAssist.Hint="Поиск врача или специальности"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="DoctorSearchTextBox_TextChanged"/>

                <TextBlock x:Name="SelectedInfoTextBlock"
                           Grid.Row="0"
                           Grid.Column="1"
                           Grid.ColumnSpan="5"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="Gray"
                           Text="Расписание не выбрано"/>

                <ComboBox x:Name="DoctorComboBox"
                          Grid.Row="1"
                          Grid.Column="0"
                          Margin="0,0,10,0"
                          materialDesign:HintAssist.Hint="Врач"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="ComboBox_SelectionChanged"/>

                <ComboBox x:Name="CabinetComboBox"
                          Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,0,10,0"
                          materialDesign:HintAssist.Hint="Кабинет"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="ComboBox_SelectionChanged"/>

                <ComboBox x:Name="DayComboBox"
                          Grid.Row="1"
                          Grid.Column="2"
                          Margin="0,0,10,0"
                          materialDesign:HintAssist.Hint="День недели"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="ComboBox_SelectionChanged"/>

                <ComboBox x:Name="StartTimeComboBox"
                          Grid.Row="1"
                          Grid.Column="3"
                          Margin="0,0,10,0"
                          materialDesign:HintAssist.Hint="Начало"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Text"
                          SelectedValuePath="Value"
                          SelectionChanged="ComboBox_SelectionChanged"/>

                <ComboBox x:Name="EndTimeComboBox"
                          Grid.Row="1"
                          Grid.Column="4"
                          Margin="0,0,10,0"
                          materialDesign:HintAssist.Hint="Окончание"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Text"
                          SelectedValuePath="Value"
                          SelectionChanged="ComboBox_SelectionChanged"/>

                <CheckBox x:Name="ActiveCheckBox"
                          Grid.Row="1"
                          Grid.Column="5"
                          Content="Активно"
                          VerticalAlignment="Center"
                          IsChecked="True"
                          Style="{StaticResource MaterialDesignCheckBox}"
                          Checked="ComboBox_SelectionChanged"
                          Unchecked="ComboBox_SelectionChanged"/>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,12">

                <Button Content="Добавить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="AddButton_Click"/>

                <Button Content="Изменить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="EditButton_Click"/>

                <Button Content="Удалить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="DeleteButton_Click"/>

                <TextBox x:Name="SearchTextBox"
                         Width="390"
                         Margin="20,0,10,0"
                         materialDesign:HintAssist.Hint="Поиск по врачу, специальности, кабинету или дню"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="SearchTextBox_TextChanged"/>

                <Button Content="Обновить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="RefreshButton_Click"/>

                <Button Content="Очистить"
                        Width="130"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="ClearButton_Click"/>
            </StackPanel>

            <ListView x:Name="ScheduleListView"
                      Grid.Row="1"
                      SelectionChanged="ScheduleListView_SelectionChanged">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID"
                                        Width="55"
                                        DisplayMemberBinding="{Binding ScheduleId}"/>

                        <GridViewColumn Header="День"
                                        Width="120"
                                        DisplayMemberBinding="{Binding DayName}"/>

                        <GridViewColumn Header="Начало"
                                        Width="90"
                                        DisplayMemberBinding="{Binding StartTimeText}"/>

                        <GridViewColumn Header="Окончание"
                                        Width="100"
                                        DisplayMemberBinding="{Binding EndTimeText}"/>

                        <GridViewColumn Header="Активно"
                                        Width="90"
                                        DisplayMemberBinding="{Binding ActiveText}"/>

                        <GridViewColumn Header="Врач"
                                        Width="240"
                                        DisplayMemberBinding="{Binding DoctorName}"/>

                        <GridViewColumn Header="Специальность"
                                        Width="160"
                                        DisplayMemberBinding="{Binding SpecialityName}"/>

                        <GridViewColumn Header="Кабинет"
                                        Width="170"
                                        DisplayMemberBinding="{Binding CabinetName}"/>

                        <GridViewColumn Header="Корпус"
                                        Width="150"
                                        DisplayMemberBinding="{Binding Corpus}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</Window>