<Window x:Class="PolyclinicApp.Views.CabinetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Кабинеты"
        Height="680"
        Width="1050"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid Background="#F5F5F5" Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Справочник кабинетов"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <materialDesign:Card Grid.Row="1"
                             Padding="18"
                             Margin="0,0,0,18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="NumberTextBox"
                         Grid.Column="0"
                         Margin="0,0,10,0"
                         materialDesign:HintAssist.Hint="Номер кабинета"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <ComboBox x:Name="CorpusComboBox"
                          Grid.Column="1"
                          Margin="0,0,10,0"
                          materialDesign:HintAssist.Hint="Корпус"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          IsEditable="True"/>

                <TextBox x:Name="PhoneTextBox"
                         Grid.Column="2"
                         Margin="0,0,10,0"
                         materialDesign:HintAssist.Hint="Телефон"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <Button Grid.Column="3"
                        Content="Очистить"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="ClearButton_Click"/>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,12">

                <Button x:Name="AddButton"
                    Content="Добавить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="AddButton_Click"/>

                <Button x:Name="EditButton"
                    Content="Изменить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="EditButton_Click"/>

                <Button x:Name="DeleteButton"
                    Content="Удалить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="DeleteButton_Click"/>

                <TextBox x:Name="SearchTextBox"
                         Width="360"
                         Margin="20,0,10,0"
                         materialDesign:HintAssist.Hint="Поиск по номеру, корпусу или телефону"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="SearchTextBox_TextChanged"/>

                <Button Content="Обновить"
                        Width="130"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="RefreshButton_Click"/>
            </StackPanel>

            <ListView x:Name="CabinetsListView"
                      Grid.Row="1"
                      SelectionChanged="CabinetsListView_SelectionChanged">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID"
                                        Width="70"
                                        DisplayMemberBinding="{Binding CabinetId}"/>

                        <GridViewColumn Header="Номер"
                                        Width="140"
                                        DisplayMemberBinding="{Binding Number}"/>

                        <GridViewColumn Header="Корпус"
                                        Width="260"
                                        DisplayMemberBinding="{Binding Corpus}"/>

                        <GridViewColumn Header="Телефон"
                                        Width="180"
                                        DisplayMemberBinding="{Binding Phone}"/>

                        <GridViewColumn Header="Используется в расписании"
                                        Width="210"
                                        DisplayMemberBinding="{Binding ScheduleCount}"/>

                        <GridViewColumn Header="Приёмов"
                                        Width="120"
                                        DisplayMemberBinding="{Binding AppointmentCount}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</Window>