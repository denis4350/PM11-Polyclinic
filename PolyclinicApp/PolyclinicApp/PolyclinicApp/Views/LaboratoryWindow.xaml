<Window x:Class="PolyclinicApp.Views.LaboratoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Лаборатория"
        Height="760"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid Background="#F5F5F5" Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Лабораторные исследования"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <materialDesign:Card Grid.Row="1"
                             Padding="18"
                             Margin="0,0,0,18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="AppointmentSearchTextBox"
                         Grid.Row="0"
                         Grid.Column="0"
                         Margin="0,0,10,12"
                         materialDesign:HintAssist.Hint="Поиск приёма по пациенту или врачу"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="AppointmentSearchTextBox_TextChanged"/>

                <TextBlock x:Name="SelectedInfoTextBlock"
                           Grid.Row="0"
                           Grid.Column="1"
                           Grid.ColumnSpan="4"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="Gray"
                           Text="Пациент и врач не выбраны"/>

                <ComboBox x:Name="AppointmentComboBox"
                          Grid.Row="1"
                          Grid.Column="0"
                          Margin="0,0,10,12"
                          materialDesign:HintAssist.Hint="Приём"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="AppointmentComboBox_SelectionChanged"/>

                <ComboBox x:Name="AnalysisTypeComboBox"
                          Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,0,10,12"
                          materialDesign:HintAssist.Hint="Тип анализа"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                <DatePicker x:Name="OrderDatePicker"
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,0,10,12"
                            materialDesign:HintAssist.Hint="Дата назначения"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>

                <DatePicker x:Name="CompletionDatePicker"
                            Grid.Row="1"
                            Grid.Column="3"
                            Margin="0,0,10,12"
                            materialDesign:HintAssist.Hint="Дата выполнения"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>

                <ComboBox x:Name="StatusComboBox"
                          Grid.Row="1"
                          Grid.Column="4"
                          Margin="0,0,0,12"
                          materialDesign:HintAssist.Hint="Статус"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"/>

                <TextBox x:Name="ResultTextBox"
                         Grid.Row="2"
                         Grid.Column="0"
                         Grid.ColumnSpan="5"
                         materialDesign:HintAssist.Hint="Результат исследования"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AcceptsReturn="True"
                         Height="80"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,12">

                <Button Content="Добавить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="AddButton_Click"/>

                <Button Content="Изменить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="EditButton_Click"/>

                <Button Content="Удалить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="DeleteButton_Click"/>

                <TextBox x:Name="SearchTextBox"
                         Width="360"
                         Margin="20,0,10,0"
                         materialDesign:HintAssist.Hint="Поиск по анализу, пациенту, врачу, результату"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="SearchTextBox_TextChanged"/>

                <Button Content="Обновить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="RefreshButton_Click"/>

                <Button Content="Очистить"
                        Width="130"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="ClearButton_Click"/>
            </StackPanel>

            <ListView x:Name="LaboratoryListView"
                      Grid.Row="1"
                      SelectionChanged="LaboratoryListView_SelectionChanged">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID"
                                        Width="55"
                                        DisplayMemberBinding="{Binding ResearchId}"/>

                        <GridViewColumn Header="Тип анализа"
                                        Width="210"
                                        DisplayMemberBinding="{Binding AnalysisType}"/>

                        <GridViewColumn Header="Пациент"
                                        Width="210"
                                        DisplayMemberBinding="{Binding PatientName}"/>

                        <GridViewColumn Header="Врач"
                                        Width="210"
                                        DisplayMemberBinding="{Binding DoctorName}"/>

                        <GridViewColumn Header="Дата назначения"
                                        Width="140"
                                        DisplayMemberBinding="{Binding OrderDateText}"/>

                        <GridViewColumn Header="Дата выполнения"
                                        Width="140"
                                        DisplayMemberBinding="{Binding CompletionDateText}"/>

                        <GridViewColumn Header="Статус"
                                        Width="120"
                                        DisplayMemberBinding="{Binding StatusText}"/>

                        <GridViewColumn Header="Результат"
                                        Width="330"
                                        DisplayMemberBinding="{Binding Result}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</Window>