<Window x:Class="PolyclinicApp.Views.DiagnosesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Диагнозы МКБ-10"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid Background="#F5F5F5" Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Справочник диагнозов МКБ-10"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <materialDesign:Card Grid.Row="1"
                             Padding="18"
                             Margin="0,0,0,18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="CodeTextBox"
                         Grid.Column="0"
                         Margin="0,0,10,0"
                         materialDesign:HintAssist.Hint="Код диагноза"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <TextBox x:Name="NameTextBox"
                         Grid.Column="1"
                         Margin="0,0,10,0"
                         materialDesign:HintAssist.Hint="Название диагноза"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <TextBox x:Name="GroupTextBox"
                         Grid.Column="2"
                         Margin="0,0,10,0"
                         materialDesign:HintAssist.Hint="Группа"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <Button Grid.Column="3"
                        Content="Очистить"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="ClearButton_Click"/>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,12">

                <Button Content="Добавить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="AddButton_Click"/>

                <Button Content="Изменить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="EditButton_Click"/>

                <Button Content="Удалить"
                        Width="130"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="DeleteButton_Click"/>

                <TextBox x:Name="SearchTextBox"
                         Width="360"
                         Margin="20,0,10,0"
                         materialDesign:HintAssist.Hint="Поиск по коду, названию или группе"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="SearchTextBox_TextChanged"/>

                <Button Content="Обновить"
                        Width="130"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="RefreshButton_Click"/>
            </StackPanel>

            <ListView x:Name="DiagnosesListView"
                      Grid.Row="1"
                      SelectionChanged="DiagnosesListView_SelectionChanged">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Код"
                                        Width="120"
                                        DisplayMemberBinding="{Binding Code}"/>

                        <GridViewColumn Header="Название"
                                        Width="500"
                                        DisplayMemberBinding="{Binding Name}"/>

                        <GridViewColumn Header="Группа"
                                        Width="260"
                                        DisplayMemberBinding="{Binding Group}"/>

                        <GridViewColumn Header="Используется в приёмах"
                                        Width="170"
                                        DisplayMemberBinding="{Binding AppointmentCount}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</Window>