<Window x:Class="PolyclinicApp.Views.AuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Журнал аудита"
        Height="760"
        Width="1300"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid Background="#F5F5F5" Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Журнал аудита"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <materialDesign:Card Grid.Row="1"
                             Padding="18"
                             Margin="0,0,0,18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="UserComboBox"
                          Grid.Row="0"
                          Grid.Column="0"
                          Margin="0,0,10,12"
                          materialDesign:HintAssist.Hint="Пользователь"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="Filter_Changed"/>

                <ComboBox x:Name="TableComboBox"
                          Grid.Row="0"
                          Grid.Column="1"
                          Margin="0,0,10,12"
                          materialDesign:HintAssist.Hint="Таблица"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          SelectionChanged="Filter_Changed"/>

                <ComboBox x:Name="OperationComboBox"
                          Grid.Row="0"
                          Grid.Column="2"
                          Margin="0,0,10,12"
                          materialDesign:HintAssist.Hint="Операция"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Code"
                          SelectionChanged="Filter_Changed"/>

                <DatePicker x:Name="DateFromPicker"
                            Grid.Row="0"
                            Grid.Column="3"
                            Margin="0,0,10,12"
                            materialDesign:HintAssist.Hint="Дата с"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            SelectedDateChanged="DateFilter_Changed"/>

                <DatePicker x:Name="DateToPicker"
                            Grid.Row="0"
                            Grid.Column="4"
                            Margin="0,0,10,12"
                            materialDesign:HintAssist.Hint="Дата по"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            SelectedDateChanged="DateFilter_Changed"/>

                <Button Grid.Row="0"
                        Grid.Column="5"
                        Content="Сбросить фильтры"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="ResetFiltersButton_Click"/>

                <TextBox x:Name="SearchTextBox"
                         Grid.Row="1"
                         Grid.Column="0"
                         Grid.ColumnSpan="4"
                         Margin="0,0,10,0"
                         materialDesign:HintAssist.Hint="Поиск по таблице, операции, IP, ID записи, логину"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="SearchTextBox_TextChanged"/>

                <Button Grid.Row="1"
                        Grid.Column="4"
                        Content="Обновить"
                        Margin="0,0,10,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="RefreshButton_Click"/>

                <Button Grid.Row="1"
                        Grid.Column="5"
                        Content="Удалить запись"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="DeleteButton_Click"/>
            </Grid>
        </materialDesign:Card>

        <ListView x:Name="AuditListView"
                  Grid.Row="2"
                  SelectionChanged="AuditListView_SelectionChanged">

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID"
                                    Width="70"
                                    DisplayMemberBinding="{Binding AuditId}"/>

                    <GridViewColumn Header="Дата и время"
                                    Width="160"
                                    DisplayMemberBinding="{Binding DateTimeText}"/>

                    <GridViewColumn Header="Пользователь"
                                    Width="170"
                                    DisplayMemberBinding="{Binding UserLogin}"/>

                    <GridViewColumn Header="Таблица"
                                    Width="170"
                                    DisplayMemberBinding="{Binding TableName}"/>

                    <GridViewColumn Header="Операция"
                                    Width="120"
                                    DisplayMemberBinding="{Binding OperationText}"/>

                    <GridViewColumn Header="ID записи"
                                    Width="110"
                                    DisplayMemberBinding="{Binding RowId}"/>

                    <GridViewColumn Header="IP-адрес"
                                    Width="130"
                                    DisplayMemberBinding="{Binding IpAddress}"/>

                    <GridViewColumn Header="Старое значение"
                                    Width="260"
                                    DisplayMemberBinding="{Binding OldValueShort}"/>

                    <GridViewColumn Header="Новое значение"
                                    Width="260"
                                    DisplayMemberBinding="{Binding NewValueShort}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <materialDesign:Card Grid.Row="3"
                             Padding="14"
                             Margin="0,18,0,0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Header="Старое значение"
                          Grid.Column="0"
                          Margin="0,0,10,0">

                    <TextBox x:Name="OldValueTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             Height="110"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </GroupBox>

                <GroupBox Header="Новое значение"
                          Grid.Column="1">

                    <TextBox x:Name="NewValueTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             Height="110"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </GroupBox>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>